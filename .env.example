# Telegram Bot Token — from @BotFather
TELEGRAM_BOT_TOKEN=

# Anthropic API Key — from console.anthropic.com
ANTHROPIC_API_KEY=

# PostgreSQL connection URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/telegram_bot

# Redis connection URL
REDIS_URL=redis://localhost:6379

# Environment
NODE_ENV=development

# Google OAuth 2.0 — from console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Set to your ngrok/Cloudflare Tunnel URL + /auth/google/callback
GOOGLE_CALLBACK_URL=https://<your-tunnel>.ngrok.io/auth/google/callback

# AES-256-GCM key for encrypting stored Google tokens (64 hex chars)
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# Webhook URL for production (leave empty to use long polling in dev)
# Set to your public HTTPS URL: https://yourdomain.com
WEBHOOK_URL=

# Per-user message rate limit (messages per 60 seconds, default 20)
RATE_LIMIT_PER_MINUTE=20
